# Environment
venv/
__pycache__/
*.pyc

# OS
.DS_Store

# IDE/Tool caches
.qwen/
.ruff_cache/

# keys
config/llm_provider_*.yaml


# Large model files (too big for Git)
# First: allow benchmark charts
!outputs/cycle-1/benchmarks/
!outputs/cycle-1/benchmarks/*.png
# Then ignore everything else
outputs/*
# But keep OUTPUT.md in outputs/ directory
!outputs/OUTPUT.md
!outputs/cycle-1/
!outputs/cycle-1/OUTPUT.md

# Temp/diagnostic logs
outputs/benchmarks/eval-run.log
outputs/benchmarks/eval-ft-checkpoint.json
outputs/benchmarks/quick/
outputs/test/
outputs/test-quick/
outputs/benchmark/
outputs/*/logs/
backup_*/

/* Firecrawl cache */
.firecrawl/

# Worktrees (isolated workspaces)
/.worktrees/
worktrees/

# Temp files
"5.0\"*
"5.0"*n
=
*.tmp

# LLM generation checkpoint
data/.llm_gen_checkpoint.json

# Old archived files
ARQUIVOS-OLD/

