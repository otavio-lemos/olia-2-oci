MODEL="mlx-community/Qwen2.5-Coder-7B-Instruct-4bit"
TRAIN_DATA="data/train.jsonl"
VALID_DATA="data/valid.jsonl"
OUTPUT_DIR="outputs/cycle-1"
PREV_ADAPTER=""
BATCH_SIZE=1
LEARNING_RATE=1e-5
LORA_RANK=32
LORA_ALPHA=64
LORA_DROPOUT=0.05
GRADIENT_ACCUMULATION=4
NUM_LAYERS=28
TARGET_MODULES="q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
ITERS=10
MAX_SEQ_LENGTH=256
VAL_BATCHES=5
EVAL_STEPS=500
LOGGING_STEPS=1
SAVE_STEPS=500
WARMUP_STEPS=558
GRADIENT_CHECKPOINTING=true
LR_SCHEDULER=cosine
WEIGHT_DECAY=0.01
SEED=42
GRADIENT_CLIP_NORM=1.5
BF16=true
