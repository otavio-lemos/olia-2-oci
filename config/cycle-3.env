MODEL="mlx-community/Llama-3.2-3B-Instruct-4bit"
TRAIN_DATA="data/train.jsonl"
VALID_DATA="data/valid.jsonl"
OUTPUT_DIR="outputs/cycle-3"
PREV_ADAPTER="outputs/cycle-2/adapters.safetensors"
EPOCHS=2
BATCH_SIZE=2
LEARNING_RATE=5e-6
LORA_RANK=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
GRADIENT_ACCUMULATION=2
NUM_LAYERS=20
ITERS=500
MAX_SEQ_LENGTH=2048
