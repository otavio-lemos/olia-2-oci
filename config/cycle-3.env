MODEL="mlx-community/Meta-Llama-3.1-8B-Instruct-4bit"
TRAIN_DATA="data/train.jsonl"
VALID_DATA="data/valid.jsonl"
OUTPUT_DIR="outputs/cycle-3"
PREV_ADAPTER="outputs/cycle-2/adapters.safetensors"
EPOCHS=2
BATCH_SIZE=8
LEARNING_RATE=1e-6
LORA_RANK=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
GRADIENT_ACCUMULATION=2
NUM_LAYERS=20
ITERS=500
MAX_SEQ_LENGTH=2048
VAL_BATCHES=5