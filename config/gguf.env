# Configuração para Export GGUF
# cycle-1.env deve ter EXPORT_GGUF=true para ativar

# Modelos base suportados para GGUF export
GGUF_BASE_MODELS="mlx-community/Meta-Llama-3.1-8B-Instruct-4bit"

# Quantizações disponíveis (separadas por vírgula)
GGUF_QUANTIZATIONS="q4,q5,q8"

# after training complete
EXPORT_GGUF=false
EXPORT_TO_OLLAMA=false