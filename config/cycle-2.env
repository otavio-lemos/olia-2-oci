MODEL="mlx-community/Meta-Llama-3.1-8B-Instruct-4bit"
TRAIN_DATA="data/train_cycle2.jsonl"
VALID_DATA="data/valid_cycle2.jsonl"
OUTPUT_DIR="outputs/cycle-2"
PREV_ADAPTER="outputs/cycle-1/adapters"
BATCH_SIZE=1
LEARNING_RATE=1.5e-4
LORA_RANK=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
GRADIENT_ACCUMULATION=1
NUM_LAYERS=16
TARGET_MODULES="q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
ITERS=5500
MAX_SEQ_LENGTH=2048
VAL_BATCHES=5
EVAL_STEPS=250
LOGGING_STEPS=1
SAVE_STEPS=600
WARMUP_STEPS=400
GRADIENT_CHECKPOINTING=true
LR_SCHEDULER=cosine
WEIGHT_DECAY=0.01
SEED=42
GRADIENT_CLIP_NORM=1.0