MODEL="mlx-community/Meta-Llama-3.1-8B-Instruct-4bit"
TRAIN_DATA="data/train.jsonl"
VALID_DATA="data/valid.jsonl"
OUTPUT_DIR="outputs/cycle-1"
PREV_ADAPTER=""
EPOCHS=2
BATCH_SIZE=1
LEARNING_RATE=2e-5
LORA_RANK=8
LORA_ALPHA=16
LORA_DROPOUT=0.0
GRADIENT_ACCUMULATION=2
# NUM_LAYERS=8
ITERS=250
MAX_SEQ_LENGTH=2048
VAL_BATCHES=5
LOGGING_STEPS=5
SAVE_STEPS=50
WARMUP_STEPS=20
GRADIENT_CHECKPOINTING=true
LR_SCHEDULER=cosine
WEIGHT_DECAY=0.01
SEED=42
GRADIENT_CLIP_NORM=1.0
CLEAR_CACHE_GB=5
# Training Results: Train Loss=0.528, Val Loss=0.434, Time=12.1min, Peak Mem=6.1GB
