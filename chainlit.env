# OCI Copilot - Chainlit Environment Configuration
# https://docs.chainlit.io/environment-variables

# =======================
# API Services
# =======================
RAG_API_URL=http://localhost:8000
MLX_SERVER_URL=http://localhost:8080

# =======================
# Model Configuration
# =======================
MODEL_PATH=outputs/cycle-1/oci-specialist

# =======================
# Agents Config
# =======================
AGENTS_CONFIG_PATH=config/oci-copilot-agents.yaml

# =======================
# UI Options
# =======================
DEFAULT_STRATEGY=default
ENABLE_QUICK_ACTIONS=true

# =======================
# Session Settings
# =======================
SESSION_TIMEOUT_SECONDS=300
REQUEST_TIMEOUT_SECONDS=30